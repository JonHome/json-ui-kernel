{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbit.app/schemas/ui-kernel/theme-ref.schema.json",
  "title": "ThemeRef",
  "description": "Symbolic theme references used by the UI kernel.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "theme": {
      "type": "string",
      "description": "Foundation theme identifier.",
      "pattern": "^[a-z0-9][a-z0-9-]*(\\.[a-z0-9][a-z0-9-]*)+$"
    },
    "domainTheme": {
      "type": "string",
      "description": "Optional domain-pack theme identifier.",
      "pattern": "^[a-z0-9][a-z0-9-]*(\\.[a-z0-9][a-z0-9-]*)+$"
    }
  }
}
